{
  "name": "vscode-slop-detector",
  "displayName": "AI SLOP Detector",
  "description": "Real-time AI-generated code quality analysis for VS Code",
  "version": "3.9.0",
  "publisher": "Flamehaven",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "code-quality",
    "linter",
    "slop-detection",
    "static-analysis"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:go"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "slop-detector.analyzeFile",
        "title": "Analyze Current File",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.analyzeWorkspace",
        "title": "Analyze Workspace",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.showHistory",
        "title": "Show File History",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.installGitHook",
        "title": "Install Git Pre-Commit Hook",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.autoFix",
        "title": "Auto-Fix Detected Issues",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.showGate",
        "title": "Show Gate Decision (SNP)",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.crossFileAnalysis",
        "title": "Run Cross-File Analysis",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.showHistoryTrends",
        "title": "Show History Trends",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.exportHistory",
        "title": "Export History to JSONL",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.initConfig",
        "title": "Bootstrap .slopconfig.yaml",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.selfCalibrate",
        "title": "Run Self-Calibration",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.showOutput",
        "title": "Show SLOP Output Panel",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.addFileToIgnore",
        "title": "Add File to .slopconfig.yaml Ignore",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.refreshTree",
        "title": "Refresh Issues",
        "category": "SLOP Detector",
        "icon": "$(refresh)"
      },
      {
        "command": "slop-detector.addModuleToAllowlist",
        "title": "Add Module to phantom_import_allowlist",
        "category": "SLOP Detector"
      },
      {
        "command": "slop-detector.showBreakdown",
        "title": "Show 4D Breakdown (why not 0.0)",
        "category": "SLOP Detector",
        "icon": "$(graph)"
      },
      {
        "command": "slop-detector.showCleanupPlan",
        "title": "Show Cleanup Plan (dead-code / dupes / unused-deps ...)",
        "category": "SLOP Detector",
        "icon": "$(checklist)"
      },
      {
        "command": "slop-detector.showPulse",
        "title": "Show Pulse Dashboard (health + hotspots)",
        "category": "SLOP Detector",
        "icon": "$(pulse)"
      },
      {
        "command": "slop-detector.showReview",
        "title": "Show Changed-Code Review (diff-aware)",
        "category": "SLOP Detector",
        "icon": "$(git-compare)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "slop-detector",
          "title": "SLOP Detector",
          "icon": "images/slop-sidebar.svg"
        }
      ]
    },
    "views": {
      "slop-detector": [
        {
          "id": "slopDetector.fileTree",
          "name": "Issues",
          "icon": "images/slop-sidebar.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "slop-detector.analyzeWorkspace",
          "when": "view == slopDetector.fileTree && !slop.hasAnalyzed",
          "group": "navigation"
        },
        {
          "command": "slop-detector.refreshTree",
          "when": "view == slopDetector.fileTree && slop.hasAnalyzed",
          "group": "navigation"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "slopDetector.fileTree",
        "contents": "No analysis results yet.\n[$(search) Analyze Workspace](command:slop-detector.analyzeWorkspace)\nAI-SLOP Detector measures structural risk in AI-generated code — stubs, phantom imports, clone clusters, and inflated docs.\n[Get Started](command:workbench.action.openWalkthrough?%22Flamehaven.vscode-slop-detector%23slop.gettingStarted%22)",
        "when": "!slop.hasAnalyzed"
      },
      {
        "view": "slopDetector.fileTree",
        "contents": "$(check) No structural risk found.\n[$(refresh) Re-scan](command:slop-detector.refreshTree)",
        "when": "slop.hasAnalyzed && slop.isClean"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "AI SLOP Detector",
      "properties": {
        "slopDetector.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable SLOP Detector"
        },
        "slopDetector.lintOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run analysis on file save"
        },
        "slopDetector.lintOnType": {
          "type": "boolean",
          "default": false,
          "description": "Run analysis while typing (may impact performance)"
        },
        "slopDetector.showInlineWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show inline warnings in editor"
        },
        "slopDetector.failThreshold": {
          "type": "number",
          "default": 50,
          "description": "Slop score threshold for errors (0-100)"
        },
        "slopDetector.warnThreshold": {
          "type": "number",
          "default": 30,
          "description": "Slop score threshold for warnings (0-100)"
        },
        "slopDetector.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python interpreter"
        },
        "slopDetector.configPath": {
          "type": "string",
          "default": "",
          "description": "Path to .slopconfig.yaml (optional)"
        },
        "slopDetector.recordHistory": {
          "type": "boolean",
          "default": true,
          "description": "Record analysis results in history database"
        },
        "slopDetector.showCalibrationHints": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when the LEDA auto-calibration milestone is reached"
        },
        "slopDetector.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show inline SLOP score and issue hints above functions (CodeLens)"
        },
        "slopDetector.domain": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "general",
            "scientific/ml",
            "scientific/numerical",
            "web/api",
            "library/sdk",
            "cli/tool",
            "bio",
            "finance"
          ],
          "enumDescriptions": [
            "Auto-detect the domain from project file patterns (default)",
            "General-purpose code; balanced 4D weights",
            "Machine-learning / AI projects",
            "Numerical and scientific computing",
            "Web services and HTTP APIs",
            "Reusable libraries and SDKs",
            "Command-line tools and scripts",
            "Bioinformatics pipelines",
            "Financial / quantitative code"
          ],
          "markdownDescription": "Domain profile used by **Bootstrap .slopconfig.yaml** (`--init`). `auto` lets the detector infer the domain from file patterns; any other value is forwarded as `--domain`."
        },
        "slopDetector.phantomImportAllowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Module names to skip in phantom_import detection (e.g. project-local flat modules). Mirrors phantom_import_allowlist in .slopconfig.yaml — entries here are shown in QuickFix suggestions."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "slop.gettingStarted",
        "title": "Get Started with AI-SLOP Detector",
        "description": "Measure structural risk in AI-generated code, read the score, patch findings, then gate and self-calibrate.",
        "steps": [
          {
            "id": "slop.gettingStarted.scan",
            "title": "Run your first scan",
            "description": "Analyze the workspace for structural risk.\n\n[Analyze Workspace](command:slop-detector.analyzeWorkspace)",
            "media": {
              "markdown": "media/step-scan.md"
            },
            "completionEvents": [
              "onCommand:slop-detector.analyzeWorkspace"
            ]
          },
          {
            "id": "slop.gettingStarted.diagnose",
            "title": "Read the score",
            "description": "Each file attributes its deficit score back to four dimensions so you can see the top driver.\n\n[Show Output](command:slop-detector.showOutput)",
            "media": {
              "markdown": "media/step-diagnose.md"
            }
          },
          {
            "id": "slop.gettingStarted.fix",
            "title": "Patch the findings",
            "description": "Apply safe fixes and use the QuickFix lightbulb on phantom imports and god functions.\n\n[Auto-Fix](command:slop-detector.autoFix)",
            "media": {
              "markdown": "media/step-fix.md"
            },
            "completionEvents": [
              "onCommand:slop-detector.autoFix"
            ]
          },
          {
            "id": "slop.gettingStarted.gate",
            "title": "Gate, then calibrate",
            "description": "Turn a one-off scan into a standing quality signal.\n\n[Show Gate](command:slop-detector.showGate) · [Self-Calibrate](command:slop-detector.selfCalibrate)",
            "media": {
              "markdown": "media/step-gate.md"
            },
            "completionEvents": [
              "onCommand:slop-detector.showGate"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs",
    "compile": "tsc -p ./",
    "check": "tsc -p ./ --noEmit",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {
    "ai-slop-detector": "file:../npm-wrapper"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.20.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flamehaven01/AI-SLOP-Detector"
  },
  "bugs": {
    "url": "https://github.com/flamehaven01/AI-SLOP-Detector/issues"
  },
  "homepage": "https://github.com/flamehaven01/AI-SLOP-Detector#readme",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/Flamehaven.vscode-slop-detector",
      "href": "https://marketplace.visualstudio.com/items?itemName=Flamehaven.vscode-slop-detector",
      "description": "VS Marketplace version"
    },
    {
      "url": "https://img.shields.io/pypi/v/ai-slop-detector.svg",
      "href": "https://pypi.org/project/ai-slop-detector/",
      "description": "Python backend version"
    }
  ],
  "license": "MIT"
}
